# =====================================================================
#  France & Sprinkles — environment variables
# ---------------------------------------------------------------------
#  1. Copy this file to ".env.local" and fill in your real values.
#  2. NEVER commit your filled-in file — add  .env*  to .gitignore.
#  3. In Vercel: Settings → Environment Variables → add each one,
#     then REDEPLOY for changes to take effect.
# =====================================================================

# ── REQUIRED ─────────────────────────────────────────────────────────

# Stripe secret key  (Dashboard → Developers → API keys)
# Use sk_test_… while testing, sk_live_… when you go live.
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Stripe webhook signing secret  (Developers → Webhooks → your endpoint)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# Airtable Personal Access Token  (https://airtable.com/create/tokens)
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Airtable Base ID  (the appXXXX… part of your base URL)
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Your live site URL  (used for checkout success / cancel redirects)
SITE_URL=https://francesprinkles.ca

# Resend API key for confirmation emails  (https://resend.com → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx


# ── OPTIONAL (defaults shown; uncomment only to override) ────────────

# Where order-alert emails are sent
# BAKERY_EMAIL=france@francesprinkles.ca

# From address for emails (your domain must be verified in Resend)
# RESEND_FROM=France & Sprinkles <orders@francesprinkles.ca>

# Airtable table names
# AIRTABLE_TABLE=Orders
# AIRTABLE_GALLERY_TABLE=Gallery

# Gallery field names
# GALLERY_PHOTO_FIELD=Photo
# GALLERY_CATEGORY_FIELD=Category
# GALLERY_NAME_FIELD=Name
